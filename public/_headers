# Service-worker and app-shell metadata must revalidate on every deployment.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.webmanifest
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache

# Long-term caching is safe for Vite's content-hashed assets.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Basic browser hardening without blocking Supabase, Cloudinary, or the Render API.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
