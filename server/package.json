{
  "name": "sahai-backend",
  "version": "1.0.0",
  "private": true,
  "description": "SahAI API with Supabase PostgreSQL production storage and SQLite development fallback.",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "reset": "node -e \"require('fs').rmSync(require('path').join(__dirname,'sahai.db'),{force:true});require('fs').rmSync(require('path').join(__dirname,'sahai.db-wal'),{force:true});require('fs').rmSync(require('path').join(__dirname,'sahai.db-shm'),{force:true});console.log('Database reset.')\""
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "pg": "^8.16.3"
  }
}
