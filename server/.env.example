# Backend environment variables (set these in Render's Environment tab).
# This file is documentation only; never commit real secrets.

PORT=4000
SAHAI_DB=/var/data/sahai.db

# Cloudinary image storage. If all three are present, uploads use Cloudinary.
# If absent, local development falls back to server/uploads/.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=sahai

# Optional local/persistent upload folder when Cloudinary is disabled.
UPLOAD_DIR=/var/data/uploads
# Supabase PostgreSQL (production)
# Copy the PostgreSQL connection string from Supabase > Connect. Use the
# transaction pooler URI on Render when IPv4/direct connection is unavailable.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_SSL=true
DATABASE_POOL_SIZE=5
# Set false only if you want an empty production database instead of demo rows.
SEED_DEMO_DATA=true
# Production application admin (backend only, minimum 10-character password).
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=replace_with_a_long_unique_password
APP_ADMIN_NAME=SahAI Admin
# Demo role/OTP login defaults off with PostgreSQL. Keep false in production.
ALLOW_DEMO_AUTH=false

# Supabase Auth token verification for Google sign-in.
# The anon/publishable key is not the service-role key.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key
# Backend-only key required to delete linked Google identities. Never expose it to Vite/browser code.
SUPABASE_SERVICE_ROLE_KEY=your_legacy_service_role_key

